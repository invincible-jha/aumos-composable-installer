# AumOS Composable Installer — environment configuration
# Copy to .env and fill in values before running locally.

# -- Core --
AUMOS_SERVICE_NAME=aumos-composable-installer
AUMOS_ENVIRONMENT=development
AUMOS_DEBUG=true

# -- Helm --
AUMOS_INSTALLER_HELM_CHART_REPOSITORY=oci://registry.aumos.ai/charts
AUMOS_INSTALLER_HELM_NAMESPACE=aumos-system
AUMOS_INSTALLER_HELM_RELEASE_NAME=aumos
AUMOS_INSTALLER_HELM_TIMEOUT_SECONDS=600
# Path to local umbrella chart for development (overrides registry)
# AUMOS_INSTALLER_UMBRELLA_CHART_DIR=./helm-umbrella

# -- Kubernetes --
# Leave empty to use the default kubeconfig (~/.kube/config)
KUBECONFIG=

# -- ArgoCD (optional) --
AUMOS_INSTALLER_ARGOCD_SERVER=
AUMOS_INSTALLER_ARGOCD_NAMESPACE=argocd
AUMOS_INSTALLER_ARGOCD_APP_PROJECT=aumos

# -- License --
# Path where the license JWT is stored after activation
AUMOS_INSTALLER_LICENSE_KEY_PATH=~/.aumos/license.key
# Path to the AumOS RSA public key for offline JWT validation (bundled with package)
# AUMOS_INSTALLER_LICENSE_PUBLIC_KEY_PATH=

# -- State --
AUMOS_INSTALLER_STATE_FILE_PATH=~/.aumos/installer-state.yaml

# -- Health Checks --
AUMOS_INSTALLER_HEALTH_CHECK_TIMEOUT_SECONDS=300
AUMOS_INSTALLER_HEALTH_CHECK_INTERVAL_SECONDS=10

# -- Manifest Discovery --
# Defaults to the module-manifests/ directory in this repo
# AUMOS_INSTALLER_MANIFEST_DIR=./module-manifests
